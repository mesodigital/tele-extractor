# ─── Telegram ───
# Bot token dari @BotFather (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=
# Restrict bot ke chat ID tertentu (angka). Biarkan kosong jika ingin terbuka.
ALLOWED_CHAT_ID=

# ─── AI / LLM API ───
# Base URL OpenAI-compatible API. Contoh:
#   OpenAI:    https://api.openai.com/v1
#   OpenRouter: https://openrouter.ai/api/v1
#   Local LLM: http://localhost:1234/v1
AI_BASE_URL=
# API key untuk AI service di atas
AI_API_KEY=
# Nama model, contoh: gpt-4o, gpt-4o-mini, gemini-2.0-flash-exp
AI_MODEL=

# ─── Google Sheets ───
# Service account email dari Google Cloud Console
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Private key service account (bisa pakai kutip 1 baris atau multiline)
GOOGLE_PRIVATE_KEY=
# ID Google Sheet (ambil dari URL spreadsheet)
GOOGLE_SHEET_ID=

# ─── Opsional ───
# Port HTTP server (default: 4746)
PORT=
# Environment: development | production (default: development)
NODE_ENV=
